# Copy this file to deploy-existing-layout.env on the closed-network server and edit it.
# Keep deploy-existing-layout.env out of GitHub if it contains real internal domains or secrets.

APP_DIR=/app/jasca
IMAGE_NAME=jasca-offline:latest
CONTAINER_NAME=jasca

# Dedicated Docker network used only by JASCA-related containers.
# It lets the JASCA container resolve http://zap-scanner:8080 by container name.
DOCKER_NETWORK=jasca-net

# Host web port. The application inside the container listens on 3000.
WEB_PORT=3005

# API port inside the container. Set EXPOSE_API_PORT=1 only for temporary diagnostics.
API_PORT=3001
EXPOSE_API_PORT=0

# Set this to the real external URL used by browsers, for example https://your-jasca.example.com
CORS_ORIGIN=

# Set a long random secret and keep it stable across redeploys.
JWT_SECRET=

# For an existing deployment, set this to the password used by the current database.
DB_PASSWORD=
DATABASE_URL=postgresql://jasca:${DB_PASSWORD}@localhost:5432/jasca
REDIS_URL=redis://localhost:6379

# Optional: mount the host Trivy cache so file scans can run without downloading DBs.
# Typical Linux examples: /root/.cache/trivy or /home/<user>/.cache/trivy
TRIVY_CACHE_MOUNT=

# Optional: maximum browser-uploaded file size for direct Trivy scans.
# Example below allows 2GB.
TRIVY_UPLOAD_MAX_BYTES=2147483648

# Optional: Syft binary used for closed-network SBOM generation fallback.
# The offline image includes syft by default.
SYFT_BINARY_PATH=syft

# Optional: defaults used when scanning standalone RPM files.
# Match these to the RPM build target, for example redhat/8, redhat/9, rocky/9.
TRIVY_RPM_OS_FAMILY=redhat
TRIVY_RPM_OS_VERSION=

# Raw Trivy JSON results are persisted under ${APP_DIR}/scan-results and mounted
# into the container so they survive restarts and power the "원본 결과 다운로드" button.
# Set retention in days to auto-delete old JSON files (0 = keep forever).
SCAN_RESULT_RETENTION_DAYS=0

# Set blank to skip mounting /etc/hosts.
HOSTS_MOUNT=/etc/hosts

# Optional: comma-separated Docker --add-host entries for internal AI/model hosts.
# Example: ai-gateway.internal:10.10.10.20,vllm.internal:10.10.10.21
EXTRA_HOSTS=

# Optional: host path to the internal root/intermediate CA used by Clustara HTTPS.
# Example: /app/jasca/certs/internal-ca.crt
INTERNAL_CA_CERT=

# Optional OWASP ZAP scanner service.
# Set ENABLE_ZAP_CONTAINER=1 when carrying zaproxy-stable-amd64.tar.gz into the closed network.
ENABLE_ZAP_CONTAINER=1
ZAP_CONTAINER_NAME=zap-scanner
ZAP_IMAGE_NAME=ghcr.io/zaproxy/zaproxy:stable
ZAP_IMAGE_ARCHIVE=/app/jasca/zaproxy-stable-amd64.tar.gz
ZAP_BASE_URL=http://zap-scanner:8080
ZAP_API_KEY=
